{
  "name": "dungeon-crawler-mmo",
  "version": "0.1.0",
  "description": "Browser-based 3D Dungeon Crawler MMO",
  "main": "server/index.js",
  "bin": "desktop-launcher.js",
  "scripts": {
    "dev": "nodemon server/index.js",
    "start": "node server/index.js",
    "desktop": "node desktop-launcher.js",
    "test": "node --test",
    "build:win-exe": "pkg . --targets node18-win-x64 --output dist/DungeonCrawlerMMO.exe"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "three": "^0.152.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/socket.io/client-dist/**/*"
    ],
    "outputPath": "dist"
  }
}
